<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Premium ATS CV Builder</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --app-bg: #0B0F19; --sidebar-bg: #111827; --border: #374151;
  --text: #F9FAFB; --text-muted: #9CA3AF; --accent: #6366F1;
  --accent-hover: #4F46E5; --danger: #ef4444;
}
* { box-sizing: border-box; }
body { margin: 0; font-family: 'Inter', sans-serif; background: var(--app-bg); color: var(--text); display: flex; height: 100vh; overflow: hidden; }

/* App UI */
.sidebar { width: 450px; background: var(--sidebar-bg); border-right: 1px solid var(--border); display: flex; flex-direction: column; }
.header-bar { padding: 20px; border-bottom: 1px solid var(--border); }
.header-bar h1 { font-size: 1.2rem; margin: 0; background: linear-gradient(135deg, #60A5FA, #A78BFA); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.form-content { flex: 1; overflow-y: auto; padding: 20px; }
.form-section { margin-bottom: 24px; padding: 16px; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border); border-radius: 8px; }
.form-section h2 { font-size: 1rem; margin: 0 0 16px 0; }
.input-group { margin-bottom: 12px; }
.input-group label { display: block; font-size: 0.85rem; margin-bottom: 6px; color: var(--text-muted); }
.input-group input, .input-group textarea, select { width: 100%; background: #1F2937; border: 1px solid var(--border); color: var(--text); padding: 10px; border-radius: 6px; font-family: inherit; transition: 0.2s; }
.input-group input:focus, .input-group textarea:focus, select:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(99,102,241,0.2); }
.input-group textarea { resize: vertical; min-height: 80px; }

.btn { background: linear-gradient(135deg, var(--accent), #8B5CF6); color: white; border: none; padding: 10px 16px; border-radius: 6px; cursor: pointer; font-weight: 500; transition: 0.2s; }
.btn:hover { box-shadow: 0 4px 12px rgba(99,102,241,0.4); transform: translateY(-1px); }
.btn-secondary { background: transparent; border: 1px solid var(--border); box-shadow: none; }
.btn-secondary:hover { background: rgba(255,255,255,0.05); transform: none; box-shadow: none; }
.dynamic-item { border: 1px dashed var(--border); padding: 12px; border-radius: 6px; position: relative; margin-bottom: 12px; }
.remove-btn { position: absolute; top: 12px; right: 12px; background: none; border: none; color: var(--danger); cursor: pointer; font-size: 1.2rem; }

/* Preview Area */
.preview-area { flex: 1; display: flex; flex-direction: column; background: #000; }
.topbar { height: 60px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 20px; background: var(--sidebar-bg); }
.canvas-container { flex: 1; overflow-y: auto; padding: 40px; display: flex; justify-content: center; align-items: flex-start; }

/* Resume Document - ATS Friendly */
.cv-page { width: 210mm; min-height: 297mm; background: white; color: #000; padding: 20mm; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.5); box-sizing: border-box; }
.cv-page h1, .cv-page h2, .cv-page h3, .cv-page p, .cv-page ul { margin: 0; padding: 0; }
.cv-page ul { padding-left: 20px; margin: 5px 0 15px 0; }
.cv-page li { margin-bottom: 4px; } /* Added spacing between bullet points */

/* Templates */
.template-1 { font-family: Arial, sans-serif; line-height: 1.5; }
.template-1 h1 { font-size: 24pt; margin-bottom: 5px; }
.template-1 .contact { font-size: 10pt; margin-bottom: 20px; }
.template-1 h2 { font-size: 14pt; border-bottom: 1px solid #000; margin: 20px 0 10px 0; text-transform: uppercase; }
.template-1 h3 { font-size: 12pt; margin-bottom: 2px; }
.template-1 .meta { font-style: italic; font-size: 10pt; margin-bottom: 5px; }

.template-2 { font-family: Georgia, serif; line-height: 1.6; }
.template-2 header { text-align: center; margin-bottom: 25px; }
.template-2 h1 { font-size: 28pt; font-weight: normal; margin-bottom: 5px; }
.template-2 .contact { font-size: 10pt; }
.template-2 h2 { font-size: 14pt; border-bottom: 2px solid #333; margin: 20px 0 10px 0; }
.template-2 h3 { font-size: 12pt; }
.template-2 .meta { font-size: 10pt; color: #555; }
.template-2 ul { list-style-type: square; }

.template-3 { font-family: Calibri, sans-serif; line-height: 1.4; }
.template-3 h1 { font-size: 26pt; color: #1E3A8A; }
.template-3 .contact { font-size: 11pt; margin-bottom: 15px; color: #3B82F6; }
.template-3 h2 { font-size: 14pt; color: #1E3A8A; border-bottom: 1px solid #BFDBFE; margin: 15px 0 10px 0; padding-bottom: 3px; }
.template-3 h3 { font-size: 12pt; }
.template-3 .meta { font-size: 11pt; font-weight: 600; }

.template-4 { font-family: Helvetica, sans-serif; line-height: 1.5; color: #222; }
.template-4 h1 { font-size: 24pt; font-weight: bold; letter-spacing: -0.5px; margin-bottom: 5px; }
.template-4 .contact { font-size: 9pt; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 25px; border-bottom: 1px solid #ddd; padding-bottom: 10px; }
.template-4 h2 { font-size: 12pt; text-transform: uppercase; letter-spacing: 1px; margin: 20px 0 10px 0; }
.template-4 h3 { font-size: 11pt; font-weight: bold; }
.template-4 .meta { font-size: 10pt; color: #666; }

.template-5 { font-family: "Times New Roman", Times, serif; line-height: 1.5; }
.template-5 header { text-align: center; margin-bottom: 20px; }
.template-5 h1 { font-size: 30pt; text-transform: uppercase; letter-spacing: 2px; }
.template-5 .contact { font-size: 11pt; font-style: italic; }
.template-5 h2 { font-size: 13pt; text-transform: uppercase; text-align: center; border-top: 1px solid #000; border-bottom: 1px solid #000; padding: 5px 0; margin: 20px 0 15px 0; letter-spacing: 1px; }
.template-5 h3 { font-size: 12pt; }
.template-5 .meta { font-style: italic; }

/* Print Styles */
@media print {
  @page { margin: 0; size: A4 portrait; }
  body, html { margin: 0; padding: 0; background: white; }
  body * { visibility: hidden; }
  .cv-page, .cv-page * { visibility: visible; }
  .cv-page { position: absolute; left: 0; top: 0; width: 210mm; margin: 0; padding: 20mm; box-shadow: none; min-height: auto; }
  .job, .edu-item { page-break-inside: avoid; }
}
</style>
</head>
<body>

<div class="sidebar">
  <div class="header-bar"><h1>ATS CV Builder</h1></div>
  <div class="form-content">
    <div class="form-section">
      <h2>Personal Information</h2>
      <div class="input-group"><label>Full Name</label><input type="text" id="i-name"></div>
      <div class="input-group"><label>Phone Number</label><input type="text" id="i-phone"></div>
      <div class="input-group"><label>Email</label><input type="email" id="i-email"></div>
      <div class="input-group"><label>LinkedIn URL</label><input type="text" id="i-linkedin"></div>
      <div class="input-group"><label>Location</label><input type="text" id="i-location"></div>
    </div>
    <div class="form-section">
      <h2>Professional Summary</h2>
      <div class="input-group"><label>3-5 line pitch</label><textarea id="i-summary"></textarea></div>
    </div>
    <div class="form-section">
      <h2>Core Competencies</h2>
      <div class="input-group"><label>Comma separated skills</label><textarea id="i-skills"></textarea></div>
    </div>
    <div class="form-section">
      <h2>Work Experience</h2>
      <div id="experience-list"></div>
      <button class="btn btn-secondary" style="width: 100%;" onclick="addExp()">+ Add Experience</button>
    </div>
    <div class="form-section">
      <h2>Education</h2>
      <div id="education-list"></div>
      <button class="btn btn-secondary" style="width: 100%;" onclick="addEdu()">+ Add Education</button>
    </div>
    <div class="form-section">
      <h2>Certifications</h2>
      <div id="cert-list"></div>
      <button class="btn btn-secondary" style="width: 100%;" onclick="addCert()">+ Add Certification</button>
    </div>
    <div class="form-section">
      <h2>Languages</h2>
      <div id="language-list"></div>
      <button class="btn btn-secondary" style="width: 100%;" onclick="addLang()">+ Add Language</button>
    </div>
  </div>
</div>

<div class="preview-area">
  <div class="topbar">
    <div style="display: flex; gap: 15px; align-items: center;">
      <label style="color: var(--text-muted); font-size: 0.9rem;">Template</label>
      <select id="template-select">
        <option value="template-1">Classic Professional</option>
        <option value="template-2">Executive</option>
        <option value="template-3">Modern ATS</option>
        <option value="template-4">Corporate Bold</option>
        <option value="template-5">Elegant Typography</option>
      </select>
    </div>
    <div style="display: flex; gap: 10px;">
      <button class="btn btn-secondary" onclick="exportImage()">📷 Export Photo</button>
      <button class="btn" onclick="exportPDF()">📄 Export PDF</button>
    </div>
  </div>
  <div class="canvas-container">
    <div id="cv-preview" class="cv-page template-1"></div>
  </div>
</div>

<script>
let data = {
  name: "John Doe", phone: "(555) 123-4567", email: "john@example.com", linkedin: "linkedin.com/in/johndoe", location: "New York, NY",
  summary: "Senior Project Manager with 10+ years of experience in Agile Methodologies and Software Development. Proven track record of delivering text processing solutions.",
  skills: "Project Management, Agile Methodologies, Scrum, Software Development, Python, CRM, React, System Architecture",
  experience: [
    { 
      title: "Senior Project Manager", 
      company: "Tech Corp", 
      dates: "Jan 2018 - Present", 
      desc: "Managed a team of 10, increasing productivity by 15% over 6 months.\nSpearheaded new IT initiative resulting in $1M savings.\nCoordinated cross-functional teams to deliver projects on time." 
    }
  ],
  education: [
    { degree: "Bachelor of Science in Computer Science", institution: "University of Technology", year: "2015", location: "Boston, MA" }
  ],
  cert: [
    { name: "Project Management Professional (PMP)", issuer: "PMI" }
  ],
  languages: [
    { name: "English", proficiency: "Native" },
    { name: "Spanish", proficiency: "Fluent" }
  ],
  template: "template-1"
};

function escapeHtml(unsafe) {
  if (!unsafe) return '';
  return unsafe.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
}

function textToBullets(text) {
  if (!text) return '';
  /* 
   * BUG FIX: Changed split('\\n') to split(/\n|\\n/)
   * This ensures it splits on ACTUAL "Enter" key presses (\n) 
   * OR hardcoded strings (\\n) in the default data. 
   */
  return text.split(/\n|\\n/).map(l => l.trim()).filter(Boolean).map(l => `<li>${escapeHtml(l)}</li>`).join('');
}

function renderPreview() {
  const cv = document.getElementById('cv-preview');
  cv.className = 'cv-page ' + data.template;
  
  let html = `<header>
    <h1>${escapeHtml(data.name)}</h1>
    <div class="contact">${[data.phone, data.email, data.linkedin, data.location].filter(Boolean).map(escapeHtml).join(' | ')}</div>
  </header>`;

  if (data.summary) {
    html += `<section><h2>Professional Summary</h2><p>${escapeHtml(data.summary)}</p></section>`;
  }

  const skills = data.skills.split(',').map(s => s.trim()).filter(Boolean);
  if (skills.length) {
    html += `<section><h2>Core Competencies</h2><ul style="columns: 2;">${skills.map(s => `<li>${escapeHtml(s)}</li>`).join('')}</ul></section>`;
  }

  if (data.experience.length) {
    html += `<section><h2>Work Experience</h2>${data.experience.map(job => `
      <div class="job" style="margin-bottom: 18px;">
        <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2px;">
          <h3>${escapeHtml(job.title)}</h3>
          <span style="font-style: normal; font-weight: 500;">${escapeHtml(job.dates)}</span>
        </div>
        <div class="meta" style="margin-bottom: 6px;">
          <span style="font-style: italic;">${escapeHtml(job.company)}</span>
        </div>
        <ul style="margin-top: 4px;">${textToBullets(job.desc)}</ul>
      </div>`).join('')}</section>`;
  }

  if (data.education.length) {
    html += `<section><h2>Education</h2>${data.education.map(edu => `
      <div class="edu-item" style="margin-bottom: 10px;">
        <div style="display: flex; justify-content: space-between; align-items: baseline;">
          <h3>${escapeHtml(edu.degree)}</h3>
          <span style="font-weight: 500;">${escapeHtml(edu.year)}</span>
        </div>
        <div class="meta">${escapeHtml(edu.institution)}${edu.location ? ', ' + escapeHtml(edu.location) : ''}</div>
      </div>`).join('')}</section>`;
  }

  if (data.cert.length) {
    html += `<section><h2>Certifications & Awards</h2><ul>
      ${data.cert.map(c => `<li><strong>${escapeHtml(c.name)}</strong> - ${escapeHtml(c.issuer)}</li>`).join('')}
    </ul></section>`;
  }

  if (data.languages && data.languages.length) {
    html += `<section><h2>Languages</h2><ul>
      ${data.languages.map(l => `<li><strong>${escapeHtml(l.name)}</strong> - ${escapeHtml(l.proficiency)}</li>`).join('')}
    </ul></section>`;
  }

  cv.innerHTML = html;
}

function bindInput(id, key) {
  const el = document.getElementById(id);
  el.value = data[key];
  el.addEventListener('input', e => { data[key] = e.target.value; renderPreview(); });
}

function renderExpForm() {
  document.getElementById('experience-list').innerHTML = data.experience.map((job, i) => `
    <div class="dynamic-item">
      <button class="remove-btn" onclick="data.experience.splice(${i}, 1); renderExpForm(); renderPreview();">&times;</button>
      <div class="input-group"><label>Title</label><input value="${escapeHtml(job.title)}" oninput="data.experience[${i}].title=this.value; renderPreview()"></div>
      <div class="input-group"><label>Company</label><input value="${escapeHtml(job.company)}" oninput="data.experience[${i}].company=this.value; renderPreview()"></div>
      <div class="input-group"><label>Dates</label><input value="${escapeHtml(job.dates)}" oninput="data.experience[${i}].dates=this.value; renderPreview()"></div>
      <div class="input-group"><label>Bullets (Press Enter for new bullet)</label><textarea oninput="data.experience[${i}].desc=this.value; renderPreview()">${escapeHtml(job.desc).replace(/\\n/g, '\n')}</textarea></div>
    </div>`).join('');
}

function renderEduForm() {
  document.getElementById('education-list').innerHTML = data.education.map((edu, i) => `
    <div class="dynamic-item">
      <button class="remove-btn" onclick="data.education.splice(${i}, 1); renderEduForm(); renderPreview();">&times;</button>
      <div class="input-group"><label>Degree</label><input value="${escapeHtml(edu.degree)}" oninput="data.education[${i}].degree=this.value; renderPreview()"></div>
      <div class="input-group"><label>Institution</label><input value="${escapeHtml(edu.institution)}" oninput="data.education[${i}].institution=this.value; renderPreview()"></div>
      <div class="input-group"><label>Year</label><input value="${escapeHtml(edu.year)}" oninput="data.education[${i}].year=this.value; renderPreview()"></div>
      <div class="input-group"><label>Location</label><input value="${escapeHtml(edu.location)}" oninput="data.education[${i}].location=this.value; renderPreview()"></div>
    </div>`).join('');
}

function renderCertForm() {
  document.getElementById('cert-list').innerHTML = data.cert.map((c, i) => `
    <div class="dynamic-item">
      <button class="remove-btn" onclick="data.cert.splice(${i}, 1); renderCertForm(); renderPreview();">&times;</button>
      <div class="input-group"><label>Name</label><input value="${escapeHtml(c.name)}" oninput="data.cert[${i}].name=this.value; renderPreview()"></div>
      <div class="input-group"><label>Issuer</label><input value="${escapeHtml(c.issuer)}" oninput="data.cert[${i}].issuer=this.value; renderPreview()"></div>
    </div>`).join('');
}

function renderLangForm() {
  document.getElementById('language-list').innerHTML = (data.languages || []).map((l, i) => `
    <div class="dynamic-item">
      <button class="remove-btn" onclick="data.languages.splice(${i}, 1); renderLangForm(); renderPreview();">&times;</button>
      <div class="input-group"><label>Language</label><input value="${escapeHtml(l.name)}" oninput="data.languages[${i}].name=this.value; renderPreview()"></div>
      <div class="input-group"><label>Proficiency</label><input value="${escapeHtml(l.proficiency)}" oninput="data.languages[${i}].proficiency=this.value; renderPreview()"></div>
    </div>`).join('');
}

function addExp() { data.experience.push({title:'', company:'', dates:'', desc:''}); renderExpForm(); renderPreview(); }
function addEdu() { data.education.push({degree:'', institution:'', year:'', location:''}); renderEduForm(); renderPreview(); }
function addCert() { data.cert.push({name:'', issuer:''}); renderCertForm(); renderPreview(); }
function addLang() { 
  window.data.languages = window.data.languages || [];
  window.data.languages.push({name:'', proficiency:''}); 
  renderLangForm(); renderPreview(); 
}

document.getElementById('template-select').addEventListener('change', e => { data.template = e.target.value; renderPreview(); });

function exportPDF() { 
  alert("To ensure ATS systems can read your text, use the browser's built-in PDF generator.\n\nIn the next window, change the Destination/Printer to 'Save as PDF'.");
  window.print(); 
}
function exportImage() {
  const el = document.getElementById('cv-preview');
  html2canvas(el, { scale: 2 }).then(canvas => {
    const link = document.createElement('a');
    link.download = 'ats-resume.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  });
}

document.addEventListener('DOMContentLoaded', () => {
  bindInput('i-name', 'name'); bindInput('i-phone', 'phone'); bindInput('i-email', 'email');
  bindInput('i-linkedin', 'linkedin'); bindInput('i-location', 'location');
  bindInput('i-summary', 'summary'); bindInput('i-skills', 'skills');
  document.getElementById('template-select').value = data.template;
  renderExpForm(); renderEduForm(); renderCertForm(); 
  if(document.getElementById('language-list')) renderLangForm();
  renderPreview();
});
</script>
</body>
</html>
